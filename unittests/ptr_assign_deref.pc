include("stdtest.ph");

class foo
{
    var a:std.int;
}

func f(a:ptr foo)
{
    std.test.same((*a).a, 123);

    (*a).a = 321;

    std.test.same((*a).a, 321);
}

func main
{
    var a:foo;

    a.a = 123;

    f(&a);

    std.test.same(a.a, 321);

    var b:ptr foo;

    b = &a;

    (*b).a = 999;

    std.test.same(a.a, 999);

    (*(&a)).a = 100;

    std.test.same(a.a, 100);
}
