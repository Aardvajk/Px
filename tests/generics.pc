include "stdtest.ph";

func<T> foo(a:T):T
{
    return a;
}

func<T> bar(a:T):T
{
    return foo<T>(a);
}

func<T> intValue():T;
func<T> charValue():T;

func main():std.null
{
    std.test.same(123, bar<std.int>(intValue<std.int>()));
    std.test.same('A', bar<std.char>(charValue<std.char>()));
}

func<T> intValue():T
{
    return 123;
}

func<T> charValue():T
{
    return 'A';
}
