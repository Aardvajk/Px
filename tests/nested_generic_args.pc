class<T> foo
{
    var a:T;
    var b:T;
}

class<T, K> woo
{
    var a:T;
    var b:K;
}

func<T, K> bar(a:foo<woo<T, K> >):foo<K>
{
    a.b.a;
    a.b.b.a;

    var b:foo<K>;
    return b;
}

func main()
{
    var a:foo<woo<std.int, foo<std.char> > >;

    var b = bar<std.int, foo<std.char> >(a);

    b.a;
}
