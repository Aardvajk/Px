include "stdtest.ph";

func foo(a:(std.int):std.int):std.null
{
    std.test.same(123, a(123));
}

func bar(a:std.int):std.int
{
    return a;
}

func ret():(std.int):std.int
{
    return bar;
}

func retf(a:(std.int):std.int):(std.int):std.int
{
    return a;
}

func main():std.null
{
    foo(bar);
    foo(ret());
    foo(retf(bar));
}
