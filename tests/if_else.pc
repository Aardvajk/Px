include "stdtest.ph";

func<T> foo(a:T, b:T):T
{
    if(a)
    {
        return a;
    }
    else
    {
        std.test.same(a, a);
    }

    return b;
}

func main():std.null
{
    std.test.same(123, foo(123, 321));
    std.test.same(321, foo(0, 321));

    std.test.same('x', foo('x', 'y'));
    std.test.same('y', foo('\0', 'y'));
}
